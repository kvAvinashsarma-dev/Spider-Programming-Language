let age = 12

if age >= 13
    say "Teenager or older"
else if age >= 3
    say "Kid"
else
    say "Toddler"

for i in 1 to 10
    say i

repeat 3 times
    say "Hip hip hooray!"

var lives = 3
while lives > 0
    lives -= 1

if age > 3 and age < 13 or not false
    say "boolean logic reads like a sentence"
