let name = ask "What is your name?"
say "Welcome, {name}!"
var count = 0
count += 1
if count > 0 and true
    say count
for i in 1 to 3
    say i
repeat 2 times
    say "hip hip"
let items = [1, 2, 3]
for item in items
    say item * 2
let ages = {"Ada": 12}
say ages["Ada"] + 1
say items.length()
say name.length()
